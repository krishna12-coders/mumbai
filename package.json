{
  "name": "mumbai-jaan-biryani",
  "version": "1.0.0",
  "description": "Premium Food Ordering - Website + Mobile App",
  "private": true,
  "workspaces": [
    "web",
    "app",
    "shared"
  ],
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "web:dev": "cd web && npm run dev",
    "web:build": "cd web && npm run build",
    "web:preview": "cd web && npm run preview",
