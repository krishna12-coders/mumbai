{
  "version": 2,
  "builds": [
    {
      "src": "web/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
  ,
  "routes": [
    { "src": "^/$", "dest": "/index.html" },
    { "src": "^/menu/?$", "dest": "/menu.html" },
    { "src": "^/dashboard/?$", "dest": "/dashboard.html" }
  ]
}
